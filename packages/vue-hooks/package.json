{
  "name": "@monorepo/vue-hooks",
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.0",
  "type": "module",
  "description": "Vue 3 Composition API hooks for monorepo",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "node scripts/generate-exports.js",
    "prebuild": "pnpm generate",
    "predev": "pnpm generate",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:sync": "node scripts/sync-docs.js",
    "docs:dev": "pnpm docs:sync && vitepress dev docs",
    "docs:build": "pnpm docs:sync && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@monorepo/eslint-config": "workspace:*",
    "@monorepo/tsconfig": "workspace:*",
    "@monorepo/vite-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0"
  }
}
