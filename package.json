{
  "name": "monorepo",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "description": "A monorepo project using pnpm workspace",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
