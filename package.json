    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "prepare": "husky",
    "branch": "node scripts/safe-checkout.js"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "less": "^4.2.0",
    "lint-staged": "^15.0.0",
    "only-allow": "^1.2.1",
    "prettier": "^3.8.3",
    "sass": "^1.70.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
