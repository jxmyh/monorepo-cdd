{
  "recommendations": [
    // Vue 开发必备
    "Vue.volar", // Vue 3 官方语言支持
    "Vue.vscode-typescript-vue-plugin", // Vue TypeScript 支持

    // Vant UI 组件支持
    "fishku.vant-snippets", // Vant 代码片段

    // ESLint 和代码质量
    "dbaeumer.vscode-eslint", // ESLint 集成

    // 格式化（可选，ESLint 已包含大部分功能）
    "esbenp.prettier-vscode", // Prettier 格式化器

    // TypeScript 增强
    "christian-kohler.path-intellisense", // 路径智能提示
    "bradlc.vscode-tailwindcss", // Tailwind CSS 支持（如果使用）
    "unocss.unocss", // UnoCSS 原子化 CSS 支持

    // Git 增强
    "eamodio.gitlens", // Git 增强工具

    //  productivity
    "formulahendry.auto-rename-tag", // 自动重命名标签
    "naumovs.color-highlight", // 颜色高亮
    "streetsidesoftware.code-spell-checker", // 拼写检查

    // Monorepo 支持
    "pnpm.coder", // pnpm 支持

    // 其他有用的插件
    "ms-vscode.vscode-typescript-next", // 最新版 TypeScript
    "yoavbls.pretty-ts-errors" // 美化 TypeScript 错误信息
  ]
}
